# ============================================================
# ProVial Backend — Variables de entorno
# ============================================================
# Para desarrollo local: copiar a .env y ajustar.
# En Docker (VM): docker-compose.yml sobreescribe DB_HOST,
# DB_PASSWORD, DATABASE_URL, REDIS_URL, CORS_ORIGIN con los
# valores del stack. Las vars que no sobreescribe toma de aquí.

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Base de datos
# Local: localhost | Docker: sobreescrito por compose (postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/provial_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=provial_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
# Local: localhost | Docker: sobreescrito por compose (redis)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — CAMBIAR EN PRODUCCIÓN
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# Local: puertos de vite dev | Docker: sobreescrito por compose
CORS_ORIGIN=http://localhost:5173,http://localhost:8081
SOCKET_IO_CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

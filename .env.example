# ============================================================
# ProVial — Variables del stack Docker (docker-compose.yml)
# ============================================================
# Copiar a .env y editar antes de correr docker compose up.
# Este archivo NO aplica al backend ni al web directamente —
# solo controla docker-compose.yml.

# IP o hostname de la VM (sin protocolo, sin puerto)
# Ejemplos: 192.168.1.100 | provial.institucion.gob.gt | localhost
VM_HOST=localhost

# Base de datos
DB_USER=postgres
DB_PASSWORD=cambiar_en_produccion

# JWT — cambiar en produccion, claves largas y aleatorias
JWT_SECRET=cambiar_en_produccion
JWT_REFRESH_SECRET=cambiar_en_produccion
